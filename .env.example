# Attio OAuth
ATTIO_CLIENT_ID=your-attio-client-id
ATTIO_CLIENT_SECRET=your-attio-client-secret
ATTIO_REDIRECT_URI=http://localhost:3000/api/auth/cli/attio/callback

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-key
