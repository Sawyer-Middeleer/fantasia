// ---------------------------------------------------------------------------
// SCRIPT — builds the DOM from DATA and runs the one meaningful motion:
// the "reach" extending from the apprentice and landing on each reachable file.
// ---------------------------------------------------------------------------

const SCRIPT = String.raw`
(function () {
  var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var SVGNS = 'http://www.w3.org/2000/svg';
  var stage = document.getElementById('stage');

  function el(tag, attrs, kids) {
    var n = document.createElement(tag);
    if (attrs) for (var k in attrs) { if (k === 'class') n.className = attrs[k]; else if (k === 'html') n.innerHTML = attrs[k]; else n.setAttribute(k, attrs[k]); }
    (kids || []).forEach(function (c) { n.appendChild(typeof c === 'string' ? document.createTextNode(c) : c); });
    return n;
  }
  function svg(tag, attrs) { var n = document.createElementNS(SVGNS, tag); for (var k in attrs) n.setAttribute(k, attrs[k]); return n; }
  function gradeClass(g) { return 'grade g' + (g || '').charAt(0).toUpperCase(); }

  // ---- Top band: identity (left) + score / grades / counts (right) ----
  var bandL = el('div', { class: 'band-l' }, [
    el('div', { class: 'kicker', html: '<span class="star">✦</span> Fantasia safety check' }),
    el('div', { class: 'project' }, [DATA.title]),
    el('p', { class: 'headline' }, [DATA.headline]),
  ]);

  var R = 42, C = 2 * Math.PI * R;
  var ring = svg('svg', { width: 92, height: 92, viewBox: '0 0 92 92' });
  ring.appendChild(svg('circle', { cx: 46, cy: 46, r: R, fill: 'none', stroke: 'rgba(255,255,255,0.10)', 'stroke-width': 8 }));
  var arc = svg('circle', { cx: 46, cy: 46, r: R, fill: 'none', stroke: scoreColor(DATA.score), 'stroke-width': 8, 'stroke-linecap': 'round', 'stroke-dasharray': C, 'stroke-dashoffset': C });
  ring.appendChild(arc);
  var ringWrap = el('div', { class: 'scorering' }, [ring, el('div', { class: 'scorenum' }, [el('b', { id: 'scoreNum' }, ['0']), el('span', {}, ['/ 100'])])]);

  var GLABELS = [['exposure','Expo'],['permissions','Perms'],['privacy','Privacy'],['context','Context'],['leverage','Lev']];
  var grades = el('div', { class: 'grades' }, GLABELS.map(function (p) {
    var g = (DATA.grades && DATA.grades[p[0]]) || '–';
    var chip = el('div', { class: gradeClass(g) }, [el('span', { class: 'g' }, [g]), el('span', { class: 'lbl' }, [p[1]])]);
    if (p[0] === 'leverage') chip.setAttribute('title', 'Leverage is assessed separately, not by the scanner.');
    return chip;
  }));
  var cc = DATA.counts || {};
  var cb = [];
  if (cc.critical) cb.push('<span class="crit"><b>' + cc.critical + '</b> critical</span>');
  if (cc.high) cb.push('<b>' + cc.high + '</b> high');
  if (cc.medium) cb.push('<b>' + cc.medium + '</b> medium');
  if (cc.low) cb.push('<b>' + cc.low + '</b> low');
  var gradeCol = el('div', { class: 'gradecol' }, [
    grades,
    el('div', { class: 'counts', html: cb.join(' · ') || 'no issues found' }),
    el('div', { class: 'gnote' }, ['Leverage assessed separately']),
  ]);
  stage.appendChild(el('div', { class: 'band' }, [bandL, el('div', { class: 'band-r' }, [ringWrap, gradeCol])]));

  // ---- One unified view: powers → exposure → the settings behind them ----
  var allFiles = DATA.exposureFiles || [];
  var reachFiles = allFiles.filter(function (f) { return f.reachable; });
  var otherFiles = allFiles.filter(function (f) { return !f.reachable; });
  var main = el('div', { class: 'main' }, [buildReachHero(reachFiles)]);
  var scroll = el('div', { class: 'scroll' });
  scroll.appendChild(reachFiles.length ? buildExposed(reachFiles, otherFiles) : buildCelebrate(otherFiles));
  scroll.appendChild(buildSettings());
  main.appendChild(scroll);
  stage.appendChild(main);

  // ---- Slim trust footer ----
  var a = DATA.access;
  stage.appendChild(el('div', { class: 'trust', html:
    'Scanned <b>' + a.filesScanned + '</b> files · <b>read ' + a.contentsReadIntoContext + ' file contents into this conversation</b> · only your project and Claude\'s own settings were opened · every value masked.' }));

  // ---- Animations ----
  if (reduce) {
    arc.setAttribute('stroke-dashoffset', String(C * (1 - DATA.score / 100)));
    document.getElementById('scoreNum').textContent = String(DATA.score);
    revealBeam();
  } else {
    animateScore(arc, C);
    animateBeam();
    // Safety net: rAF/CSS transitions are throttled in a background tab, which
    // would freeze the count-up and leave the beam rows hidden. Force the resting
    // state regardless, a beat after the intro.
    setTimeout(function () {
      arc.setAttribute('stroke-dashoffset', String(C * (1 - DATA.score / 100)));
      document.getElementById('scoreNum').textContent = String(DATA.score);
      revealBeam();
    }, 1600);
  }

  // =====================================================================
  function scoreColor(s) { return s >= 85 ? '#6fae8f' : s >= 60 ? '#e8b54b' : '#e2563f'; }

  function animateScore(arcEl, circ) {
    var target = DATA.score, start = null, dur = 1100;
    var label = document.getElementById('scoreNum');
    function step(t) {
      if (start === null) start = t;
      var p = Math.min((t - start) / dur, 1), eased = 1 - Math.pow(1 - p, 3);
      arcEl.setAttribute('stroke-dashoffset', String(circ * (1 - (target / 100) * eased)));
      label.textContent = String(Math.round(target * eased));
      if (p < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }

  // The hero: what Claude can do here, as capability chips, explicitly tied to
  // the settings section below (settings are the cause; reach is the effect).
  function buildReachHero(reach) {
    var caps = (DATA.reachSummary && DATA.reachSummary.length) ? DATA.reachSummary : ['open files in this project'];
    var capEls = caps.map(function (c, i) {
      return el('span', { class: 'cap' + (i === 0 ? '' : ' warn') }, [c]);
    });
    var tie = reach.length
      ? 'These powers come from your settings below — and they put the ' + reach.length + ' file' + (reach.length === 1 ? '' : 's') + ' below within reach.'
      : 'These powers come from your settings below. Right now nothing sensitive sits within that reach.';
    return el('div', { class: 'reachhero' }, [
      el('span', { class: 'glyph' }, ['🧹']),
      el('div', {}, [
        el('div', { class: 'who' }, ['Claude can:']),
        el('div', { class: 'caps' }, capEls),
        el('div', { class: 'tie' }, [tie]),
      ]),
    ]);
  }

  function buildExposed(reach, other) {
    var list = el('div', {});
    reach.forEach(function (f) { list.appendChild(beamRow(f, true)); });
    if (other.length) {
      list.appendChild(el('div', { class: 'tie', style: 'margin:9px 0 6px' }, ['Sensitive, but Claude can’t reach these:']));
      other.forEach(function (f) { list.appendChild(beamRow(f, false)); });
    }
    return el('div', { class: 'sect exposed' }, [
      el('h2', { html: 'What’s exposed <small>' + reach.length + ' Claude can reach</small><span class="hint">tap a row for details</span>' }),
      list,
    ]);
  }

  function buildCelebrate(other) {
    var hasOther = !!(other && other.length);
    var banner = el('div', { class: 'celebrate' + (hasOther ? ' compact' : '') }, [
      el('div', { class: 'check' }, ['✓']),
      el('div', { class: 'big' }, ['Nothing sensitive is in reach']),
      el('div', { class: 'sub' }, [hasOther
        ? 'Claude can’t get to anything risky here — the sensitive files below are all out of its reach.'
        : 'Claude can’t get to anything risky in this project — you’re in good shape. The settings below are just notes.']),
    ]);
    // Even with nothing reachable, still list any sensitive-but-protected files so
    // the user can see — and verify — exactly what their deny rules are guarding.
    if (!hasOther) return banner;
    var list = el('div', {});
    other.forEach(function (f) { list.appendChild(beamRow(f, false)); });
    return el('div', { class: 'sect exposed' }, [
      banner,
      el('h2', { html: 'Sensitive, but out of reach <small>' + other.length + ' protected</small><span class="hint">tap a row for details</span>' }),
      list,
    ]);
  }

  function beamRow(f, reachable) {
    var bits = [
      el('span', { class: 'arrow' }, [reachable ? 'can open →' : 'can’t reach']),
      el('span', { class: 'fn' }, [baseName(f.file)]),
      el('span', { class: 'meta' }, [' · ' + f.count + (f.count === 1 ? ' item' : ' items') + ' · ' + (f.severity || 'info')]),
    ];
    if (DATA.baselineActive && f.isNew) bits.push(el('span', { class: 'tag newt' }, ['new']));
    bits.push(el('span', { class: 'chev' }, ['▸']));
    var head = el('div', { class: 'bhead' }, bits);

    var detail = el('div', { class: 'detail' });
    var sm = (f.marks || []).filter(function (m) { return m.redactedMatch; });
    if (sm.length) {
      detail.appendChild(el('div', { class: 'drow', html: '<span class="lbl">found</span>' + sm.map(function (m) {
        return (m.line ? '<span class="loc">line ' + escJs(m.line) + '</span> ' : '') + '<code>' + escJs(m.redactedMatch) + '</code>';
      }).join('  ') }));
    }
    if (f.why) detail.appendChild(el('div', { class: 'drow', html: '<span class="lbl">why</span>' + escJs(f.why) }));
    if (f.fix) detail.appendChild(el('div', { class: 'drow', html: '<span class="lbl">fix</span>' + escJs(f.fix) }));
    detail.appendChild(el('div', { class: 'drow', html: '<span class="lbl">where</span><span class="loc">' + escJs(f.file) + '</span>' }));

    var row = el('div', { class: 'brow' + (reachable ? '' : ' safe') }, [head, detail]);
    head.addEventListener('click', function () { row.classList.toggle('open'); });
    return row;
  }

  function revealBeam() { each('.brow', function (r) { r.style.opacity = '1'; r.style.transform = 'none'; }); }
  function animateBeam() {
    each('.brow', function (r, i) {
      r.style.opacity = '0'; r.style.transform = 'translateX(-8px)';
      r.style.transition = 'opacity .35s ease, transform .35s ease';
      setTimeout(function () { r.style.opacity = '1'; r.style.transform = 'none'; }, 250 + i * 110);
    });
  }

  // Settings findings as an accordion — the cause of the reach above. Collapsed
  // stays dense; each expands to why, how it was detected, the fix, and where.
  function buildSettings() {
    var sf = DATA.settingsFindings || [];
    var list = el('div', { class: 'plist' });
    sf.forEach(function (f) {
      var bits = [
        el('span', { class: 'sev s-' + escJs(f.severity || 'info') }, [f.severity || 'info']),
        el('span', { class: 'stitle' }, [f.title || '']),
      ];
      if (f.file) bits.push(el('span', { class: 'file' }, [f.file]));
      bits.push(el('span', { class: 'chev' }, ['▸']));
      var head = el('div', { class: 'shead' }, bits);

      var detail = el('div', { class: 'detail' });
      if (f.why) detail.appendChild(el('div', { class: 'drow', html: '<span class="lbl">why</span>' + escJs(f.why) }));
      if (f.evidence) detail.appendChild(el('div', { class: 'drow', html: '<span class="lbl">how we know</span>' + escJs(f.evidence) }));
      if (f.fix) detail.appendChild(el('div', { class: 'drow', html: '<span class="lbl">fix</span>' + escJs(f.fix) }));
      if (f.file) detail.appendChild(el('div', { class: 'drow', html: '<span class="lbl">where</span><span class="loc">' + escJs(f.file) + (f.line ? ':' + escJs(f.line) : '') + '</span>' }));
      if (!f.why && !f.evidence && !f.fix) detail.appendChild(el('div', { class: 'drow loc' }, ['No extra detail for this one.']));

      var row = el('div', { class: 'srow' }, [head, detail]);
      head.addEventListener('click', function () { row.classList.toggle('open'); });
      list.appendChild(row);
    });
    return el('div', { class: 'sect settings' }, [
      el('h2', { html: 'The settings behind this <small>' + sf.length + '</small><span class="hint">tap a row for details</span>' }),
      list,
    ]);
  }

  // helpers
  function baseName(p) { var s = String(p).split(/[\\\/]/); return s[s.length - 1]; }
  function each(sel, fn) { Array.prototype.forEach.call(document.querySelectorAll(sel), fn); }
  function escJs(s) { return String(s == null ? '' : s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
})();
`;

// ---------------------------------------------------------------------------
// MAIN
// ---------------------------------------------------------------------------

function main() {
  const args = parseArgs(process.argv.slice(2));
  let raw;
  try {
    raw = readInput(args.input);
  } catch (e) {
    process.stderr.write(`fantasia-visual: could not read input (${e && e.message ? e.message : e}). Pipe \`fantasia-scan --json\` in, or pass a JSON file path.\n`);
    process.exit(1);
    return;
  }

  let scan;
  try {
    scan = JSON.parse(raw);
  } catch (e) {
    process.stderr.write(`fantasia-visual: input was not valid JSON. Expected the output of \`fantasia-scan --json\`.\n`);
    process.exit(1);
    return;
  }

  const model = buildModel(scan, args.title);
  const html = renderHtml(model);

  if (args.out) {
    fs.writeFileSync(args.out, html, 'utf8');
    process.stderr.write(`fantasia-visual: wrote ${args.out}\n`);
  } else {
    // Write to stdout and let the process exit naturally once the buffer drains.
    // Calling process.exit(0) here would truncate a piped/redirected report on
    // Windows, where stdout is async and may not have flushed yet.
    process.stdout.write(html);
  }
}

main();
