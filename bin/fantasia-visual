#!/usr/bin/env node
/*
 * fantasia-visual — render a scan's redacted JSON into a single self-contained
 * HTML page: a warm, legible "reachability map" of your project's safety health.
 *
 * Zero external dependencies (Node built-ins only). Cross-platform.
 *
 * It reads ONLY the redacted JSON that `fantasia-scan --json` produces — never a
 * project file. A raw secret value never enters here; the scan already redacted
 * everything (we only ever show `redactedMatch`, e.g. AKIA••••).
 *
 * Usage:
 *   node bin/fantasia-scan <path> --json | node bin/fantasia-visual --out report.html
 *   node bin/fantasia-visual scan.json --out report.html
 *   node bin/fantasia-visual scan.json            # HTML to stdout
 *
 * Design (v1): credibility-first, charm as accent. The center of gravity is the
 * reachability picture — what sensitive thing Claude can actually reach — framed
 * by the score, the five grades, and the "read 0 file contents" trust proof.
 */

'use strict';

const fs = require('fs');

// ---------------------------------------------------------------------------
// Arg parsing
// ---------------------------------------------------------------------------

function parseArgs(argv) {
  const args = { input: null, out: null, title: null };
  // Consume the value after a flag, erroring if it's missing or is itself a flag
  // (otherwise `--out` with no path would silently fall through to stdout).
  const value = (i, flag) => {
    const v = argv[i];
    if (v === undefined || v.startsWith('--')) {
      process.stderr.write(`fantasia-visual: ${flag} requires a value.\n`);
      process.exit(1);
    }
    return v;
  };
  for (let i = 0; i < argv.length; i++) {
    const a = argv[i];
    if (a === '--out') args.out = value(++i, '--out');
    else if (a.startsWith('--out=')) args.out = a.slice('--out='.length);
    else if (a === '--title') args.title = value(++i, '--title');
    else if (a.startsWith('--title=')) args.title = a.slice('--title='.length);
    else if (a.startsWith('--')) { /* ignore unknown flags */ }
    else if (args.input === null) args.input = a;
  }
  return args;
}

function readInput(inputPath) {
  // From a file arg, or stdin (fd 0) when piped.
  if (inputPath) return fs.readFileSync(inputPath, 'utf8');
  return fs.readFileSync(0, 'utf8');
}

// ---------------------------------------------------------------------------
// HTML escaping — every dynamic string passes through this before it lands in
// the document, so a redacted match or filename can never break out into markup.
// ---------------------------------------------------------------------------

function esc(s) {
  return String(s == null ? '' : s)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

// ---------------------------------------------------------------------------
// Severity / grade helpers
// ---------------------------------------------------------------------------

const SEVERITY_RANK = { critical: 5, high: 4, medium: 3, low: 2, info: 1 };

function worseSeverity(a, b) {
  if (!a) return b;
  if (!b) return a;
  return (SEVERITY_RANK[a] || 0) >= (SEVERITY_RANK[b] || 0) ? a : b;
}

// ---------------------------------------------------------------------------
// Model — shape the raw scan JSON into exactly what the page draws.
//
// The map's nodes are FILES that hold something sensitive (the `exposure`
// dimension). A file node is "reachable" when any finding on it is reachable.
// Settings-level findings (permissions / privacy / context) are not files on the
// map — they describe HOW MUCH reach Claude has, and frame the picture instead.
// ---------------------------------------------------------------------------

function buildModel(scan, titleOverride) {
  const summary = scan.summary || {};
  const access = scan.access || {};
  const all = Array.isArray(scan.findings) ? scan.findings : [];

  // Dismissed findings never appear — the scanner already excluded them from
  // the score; we keep them out of the picture too.
  const findings = all.filter((f) => !f.ignored);

  const baselineActive = summary.newCount != null;

  // --- Exposure files (the map nodes) ---------------------------------------
  // Group exposure findings by file, deduping the secret/sensitive item by line
  // so a single .env with five keys is one node with five marks, not five nodes.
  const fileMap = new Map();
  for (const f of findings) {
    if (f.dimension !== 'exposure' || !f.file) continue;
    let node = fileMap.get(f.file);
    if (!node) {
      node = {
        file: f.file,
        reachable: false,
        severity: null,
        isNew: false,
        why: '', fix: '',
        marks: new Map(), // key: line or `_<id>` -> { line, redactedMatch }
      };
      fileMap.set(f.file, node);
    }
    if (f.reachable === true) node.reachable = true;
    if (f.isNew === true) node.isNew = true;
    node.severity = worseSeverity(node.severity, f.severity);
    // `reachable-secret` is a correlation marker for an underlying secret/sensitive
    // finding on the same file — it flips reachability but is not its own item.
    if (f.id === 'reachable-secret') continue;
    if (!node.why && f.why) node.why = f.why;
    if (!node.fix && f.fix) node.fix = f.fix;
    // Dedup a secret by line; file-level (line-null) findings stay distinct by id
    // so two different categories on one file aren't collapsed into one.
    const key = f.line == null ? '_' + f.id : String(f.line);
    const existing = node.marks.get(key);
    // Prefer a mark that carries a redactedMatch (the raw secret finding) over a
    // bare correlation marker for the same line.
    if (!existing || (!existing.redactedMatch && f.redactedMatch)) {
      node.marks.set(key, { line: f.line, redactedMatch: f.redactedMatch || (existing && existing.redactedMatch) || null });
    }
  }

  const exposureFiles = Array.from(fileMap.values())
    .map((n) => ({
      file: n.file,
      reachable: n.reachable,
      severity: n.severity,
      isNew: n.isNew,
      why: n.why, fix: n.fix,
      count: n.marks.size,
      marks: Array.from(n.marks.values()).sort((a, b) => (a.line || 0) - (b.line || 0)),
    }))
    // Reachable first; in baseline mode, new before reviewed; then severity, then count.
    .sort((a, b) => {
      if (a.reachable !== b.reachable) return a.reachable ? -1 : 1;
      if (baselineActive && a.isNew !== b.isNew) return a.isNew ? -1 : 1;
      const s = (SEVERITY_RANK[b.severity] || 0) - (SEVERITY_RANK[a.severity] || 0);
      if (s !== 0) return s;
      return b.count - a.count;
    });

  const reachableCount = exposureFiles.filter((n) => n.reachable).length;

  // --- Reach posture (drives glow width/brightness, subtly) -----------------
  // Permissions grade is the honest proxy for how wide Claude's reach is.
  const grades = summary.grades || {};
  const permGrade = grades.permissions || null;

  // --- Settings findings (framing, not map nodes) ---------------------------
  const settingsFindings = findings
    .filter((f) => f.dimension !== 'exposure')
    .sort((a, b) => (SEVERITY_RANK[b.severity] || 0) - (SEVERITY_RANK[a.severity] || 0));

  // What Claude can reach, in plain phrases, grounded in the findings actually
  // present — this is the honest descriptor under the "Claude" node in the beam.
  const reachSummary = buildReachSummary(settingsFindings);

  // --- Headline: one plain sentence, derived from what was actually found ----
  const headline = buildHeadline({
    score: summary.score,
    reachableCount,
    counts: summary.counts || {},
    baselineActive,
    newCount: summary.newCount,
  });

  // Coerce every number that lands in the page to an integer. The scanner always
  // emits integers here, but this renderer also accepts an arbitrary JSON file, so
  // a non-numeric value must never survive into an `innerHTML` string downstream.
  const counts = {
    critical: toInt((summary.counts || {}).critical),
    high: toInt((summary.counts || {}).high),
    medium: toInt((summary.counts || {}).medium),
    low: toInt((summary.counts || {}).low),
  };

  return {
    title: titleOverride || projectName(scan.scannedRoot),
    score: typeof summary.score === 'number' ? summary.score : 0,
    grades,
    permGrade,
    counts,
    baselineActive,
    newCount: summary.newCount,
    headline,
    access: {
      filesScanned: toInt(access.filesScanned),
      contentsReadIntoContext: toInt(access.contentsReadIntoContext),
    },
    exposureFiles,
    settingsFindings,
    reachSummary,
  };
}

// Plain-English phrases for what Claude can currently do, derived from which
// permission/privacy findings are present. "Open files here" is always true for
// a project agent; the rest are added only when the matching finding exists.
function buildReachSummary(settingsFindings) {
  const ids = new Set(settingsFindings.map((f) => f.id));
  const has = (list) => list.some((id) => ids.has(id));
  const out = ['open files in this project'];
  if (has(['bash-wide-open', 'network-bash-allowed', 'env-runner-allowed', 'mode-bypass-permissions', 'mode-auto'])) {
    out.push('run shell commands');
  }
  if (has(['mcp-wide-open', 'mcp-write-capable'])) out.push('use connected tools');
  if (has(['webfetch-all-domains', 'webfetch-preflight-off'])) out.push('reach the web');
  return out;
}

// Coerce to a non-negative integer; anything non-numeric (including injected
// markup like "<img onerror=…>") collapses to 0.
function toInt(v) {
  const n = Math.floor(Number(v));
  return Number.isFinite(n) && n > 0 ? n : 0;
}

function projectName(root) {
  if (!root) return 'your project';
  const parts = String(root).split(/[\\/]/).filter(Boolean);
  return parts.length ? parts[parts.length - 1] : 'your project';
}

function buildHeadline({ score, reachableCount, counts, baselineActive, newCount }) {
  if (baselineActive && newCount === 0) {
    return 'Nothing new since your last checkup — you’re holding steady.';
  }
  if (baselineActive && newCount > 0) {
    return 'Since your last checkup, ' + newCount + (newCount === 1 ? ' new thing needs' : ' new things need') + ' a look.';
  }
  if (reachableCount > 0) {
    const noun = reachableCount === 1 ? 'one sensitive file' : `${reachableCount} sensitive files`;
    return `Start here: ${noun} Claude can actually reach. Then a few cleanups.`;
  }
  if ((counts.critical || 0) + (counts.high || 0) > 0) {
    return 'A couple of things worth tightening — nothing reachable is exposed.';
  }
  if (score >= 85) return 'Your setup’s in good shape — just a couple of small notes.';
  return 'A few things worth knowing, none of them urgent.';
}

// ---------------------------------------------------------------------------
// Render
// ---------------------------------------------------------------------------

function renderHtml(model) {
  // The page draws itself from this single embedded blob — no network, no deps.
  const data = JSON.stringify({
    title: model.title,
    score: model.score,
    grades: model.grades,
    permGrade: model.permGrade,
    counts: model.counts,
    headline: model.headline,
    access: model.access,
    baselineActive: model.baselineActive,
    newCount: model.newCount,
    exposureFiles: model.exposureFiles,
    reachSummary: model.reachSummary,
    settingsFindings: model.settingsFindings.map((f) => ({
      title: f.title, severity: f.severity, file: f.file, line: f.line,
      why: f.why, evidence: f.evidence, fix: f.fix,
    })),
  })
    // Guard the closing-tag sequence so the JSON can't break out of <script>.
    .replace(/</g, '\\u003c');

  return `<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Fantasia — ${esc(model.title)}</title>
<style>${STYLE}</style>
</head>
<body>
<main id="stage" aria-live="polite">
  <noscript><p class="noscript">This report needs JavaScript to render. For a no-JavaScript version, re-run the safety check and choose the written summary.</p></noscript>
</main>
<script>
const DATA = JSON.parse("${jsString(data)}");
${SCRIPT}
</script>
</body>
</html>
`;
}

// Encode a JSON string for safe embedding inside a double-quoted JS string.
function jsString(s) {
  return s
    .replace(/\\/g, '\\\\')
    .replace(/"/g, '\\"')
    .replace(/\n/g, '\\n')
    .replace(/\r/g, '\\r')
    .replace(/\u2028/g, '\\u2028')
    .replace(/\u2029/g, '\\u2029');
}

