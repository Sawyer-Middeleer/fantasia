// ---------------------------------------------------------------------------
// SCRIPT — builds the DOM from DATA and runs the one meaningful motion:
// the "reach" extending from the apprentice and landing on each reachable file.
// ---------------------------------------------------------------------------

const SCRIPT = String.raw`
(function () {
  var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var SVGNS = 'http://www.w3.org/2000/svg';
  var stage = document.getElementById('stage');

  function el(tag, attrs, kids) {
    var n = document.createElement(tag);
    if (attrs) for (var k in attrs) { if (k === 'class') n.className = attrs[k]; else if (k === 'html') n.innerHTML = attrs[k]; else n.setAttribute(k, attrs[k]); }
    (kids || []).forEach(function (c) { n.appendChild(typeof c === 'string' ? document.createTextNode(c) : c); });
    return n;
  }
  function svg(tag, attrs) { var n = document.createElementNS(SVGNS, tag); for (var k in attrs) n.setAttribute(k, attrs[k]); return n; }
  function gradeClass(g) { return 'grade g' + (g || '').charAt(0).toUpperCase(); }

  // ---- Top band: identity (left) + score / grades / counts (right) ----
  var bandL = el('div', { class: 'band-l' }, [
    el('div', { class: 'kicker', html: '<span class="star">✦</span> Fantasia safety check' }),
    el('div', { class: 'project' }, [DATA.title]),
    el('p', { class: 'headline' }, [DATA.headline]),
  ]);

  var R = 42, C = 2 * Math.PI * R;
  var ring = svg('svg', { width: 92, height: 92, viewBox: '0 0 92 92' });
  ring.appendChild(svg('circle', { cx: 46, cy: 46, r: R, fill: 'none', stroke: 'rgba(255,255,255,0.10)', 'stroke-width': 8 }));
  var arc = svg('circle', { cx: 46, cy: 46, r: R, fill: 'none', stroke: scoreColor(DATA.score), 'stroke-width': 8, 'stroke-linecap': 'round', 'stroke-dasharray': C, 'stroke-dashoffset': C });
  ring.appendChild(arc);
  var ringWrap = el('div', { class: 'scorering' }, [ring, el('div', { class: 'scorenum' }, [el('b', { id: 'scoreNum' }, ['0']), el('span', {}, ['/ 100'])])]);

  var GLABELS = [['exposure','Expo'],['permissions','Perms'],['privacy','Privacy'],['context','Context'],['leverage','Lev']];
  var grades = el('div', { class: 'grades' }, GLABELS.map(function (p) {
    var g = (DATA.grades && DATA.grades[p[0]]) || '–';
    var chip = el('div', { class: gradeClass(g) }, [el('span', { class: 'g' }, [g]), el('span', { class: 'lbl' }, [p[1]])]);
    if (p[0] === 'leverage') chip.setAttribute('title', 'Leverage is assessed separately, not by the scanner.');
    return chip;
  }));
  var cc = DATA.counts || {};
  var cb = [];
  if (cc.critical) cb.push('<span class="crit"><b>' + cc.critical + '</b> critical</span>');
  if (cc.high) cb.push('<b>' + cc.high + '</b> high');
  if (cc.medium) cb.push('<b>' + cc.medium + '</b> medium');
  if (cc.low) cb.push('<b>' + cc.low + '</b> low');
  var gradeCol = el('div', { class: 'gradecol' }, [
    grades,
    el('div', { class: 'counts', html: cb.join(' · ') || 'no issues found' }),
    el('div', { class: 'gnote' }, ['Leverage assessed separately']),
  ]);
  stage.appendChild(el('div', { class: 'band' }, [bandL, el('div', { class: 'band-r' }, [ringWrap, gradeCol])]));

  // ---- Main grid: reach map | findings ----
  stage.appendChild(el('div', { class: 'grid' }, [buildMap(), buildFindings()]));

  // ---- Slim trust footer ----
  var a = DATA.access;
  stage.appendChild(el('div', { class: 'trust', html:
    'Scanned <b>' + a.filesScanned + '</b> files · <b>read ' + a.contentsReadIntoContext + ' file contents into this conversation</b> · never looked above your project folder · every value masked.' }));

  // ---- Animations ----
  if (reduce) {
    arc.setAttribute('stroke-dashoffset', String(C * (1 - DATA.score / 100)));
    document.getElementById('scoreNum').textContent = String(DATA.score);
    settleMap();
  } else {
    animateScore(arc, C);
    animateMap();
    // Safety net: rAF and CSS transitions are throttled when a tab is in the
    // background, which would freeze the count-up and the reach mid-flight.
    // Guarantee the resting state lands regardless, a beat after the sequence.
    setTimeout(function () {
      arc.setAttribute('stroke-dashoffset', String(C * (1 - DATA.score / 100)));
      document.getElementById('scoreNum').textContent = String(DATA.score);
      settleMap();
    }, 4200);
  }

  // =====================================================================
  function scoreColor(s) { return s >= 85 ? '#6fae8f' : s >= 60 ? '#e8b54b' : '#e2563f'; }

  function animateScore(arcEl, circ) {
    var target = DATA.score, start = null, dur = 1100;
    var label = document.getElementById('scoreNum');
    function step(t) {
      if (start === null) start = t;
      var p = Math.min((t - start) / dur, 1), eased = 1 - Math.pow(1 - p, 3);
      arcEl.setAttribute('stroke-dashoffset', String(circ * (1 - (target / 100) * eased)));
      label.textContent = String(Math.round(target * eased));
      if (p < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }

  function mapGeom() {
    var W = 600, H = 560, cx = W / 2, cy = H / 2;
    var files = DATA.exposureFiles || [];
    var n = files.length || 1;
    var ringR = Math.min(200, 130 + n * 12);
    var nodes = files.map(function (f, i) {
      var ang = (-Math.PI / 2) + (2 * Math.PI * i / n);
      return { f: f, x: cx + ringR * Math.cos(ang), y: cy + ringR * Math.sin(ang) };
    });
    return { W: W, H: H, cx: cx, cy: cy, ringR: ringR, nodes: nodes };
  }

  function buildMap() {
    var g = mapGeom();
    var s = svg('svg', { class: 'map', viewBox: '0 0 ' + g.W + ' ' + g.H, preserveAspectRatio: 'xMidYMid meet', role: 'img', 'aria-label': 'A map of files Claude can reach. Files with sensitive contents that Claude can reach are shown in red.' });

    // soft reach glow behind the apprentice — width nods to permissions breadth
    var glowR = DATA.permGrade && /^[DF]/.test(DATA.permGrade) ? g.ringR + 64 : g.ringR + 24;
    var glow = svg('circle', { cx: g.cx, cy: g.cy, r: glowR, fill: 'url(#reachGlow)', opacity: 0 });
    glow.setAttribute('id', 'reachGlow-c');
    var defs = svg('defs', {});
    var rad = svg('radialGradient', { id: 'reachGlow' });
    rad.appendChild(svg('stop', { offset: '0%', 'stop-color': 'rgba(232,181,75,0.20)' }));
    rad.appendChild(svg('stop', { offset: '100%', 'stop-color': 'rgba(232,181,75,0)' }));
    defs.appendChild(rad); s.appendChild(defs); s.appendChild(glow);

    // safe bulk — muted dots scattered in a soft annulus, capped
    var safe = Math.min(DATA.safeFileCount, 40), safeG = svg('g', { id: 'safeDots' });
    for (var i = 0; i < safe; i++) {
      var ang = (i / Math.max(safe, 1)) * 2 * Math.PI + 0.6, rr = g.ringR + 70 + (i % 5) * 9;
      var d = svg('circle', { cx: g.cx + rr * Math.cos(ang), cy: g.cy + rr * Math.sin(ang) * 0.55, r: 2.4, fill: '#6fae8f', opacity: 0 });
      safeG.appendChild(d);
    }
    s.appendChild(safeG);

    // reach lines (apprentice -> reachable files) + file nodes
    var lines = svg('g', { id: 'reachLines' }), nodesG = svg('g', { id: 'fileNodes' });
    g.nodes.forEach(function (nd, i) {
      var reach = nd.f.reachable;
      if (reach) {
        var ln = svg('line', { x1: g.cx, y1: g.cy, x2: nd.x, y2: nd.y, stroke: '#e2563f', 'stroke-width': 2, 'stroke-dasharray': 6, opacity: 0 });
        ln.setAttribute('data-i', i); lines.appendChild(ln);
      }
      var color = reach ? '#e2563f' : '#8b86a6';
      var grp = svg('g', { 'data-i': i, opacity: 0 }); grp.setAttribute('class', 'fnode');
      grp.appendChild(svg('circle', { cx: nd.x, cy: nd.y, r: reach ? 13 : 9, fill: reach ? 'rgba(226,86,63,0.18)' : 'rgba(139,134,166,0.15)', stroke: color, 'stroke-width': 2 }));
      if (nd.f.count > 1) {
        var badge = svg('text', { x: nd.x, y: nd.y + 4, 'text-anchor': 'middle', 'font-size': 11, fill: color, 'font-weight': 'bold' });
        badge.textContent = String(nd.f.count); grp.appendChild(badge);
      }
      var label = svg('text', { x: nd.x, y: nd.y + (nd.y > g.cy ? 30 : -22), 'text-anchor': 'middle', 'font-size': 13, fill: '#f4ecd8' });
      label.textContent = baseName(nd.f.file); grp.appendChild(label);
      if (reach) {
        var tag = svg('text', { x: nd.x, y: nd.y + (nd.y > g.cy ? 46 : -38), 'text-anchor': 'middle', 'font-size': 10, fill: '#f08a76' });
        tag.textContent = 'reachable'; grp.appendChild(tag);
      }
      nodesG.appendChild(grp);
    });
    s.appendChild(lines); s.appendChild(nodesG);

    // the apprentice (center) — a small broom glyph in a gold disc
    var app = svg('g', { id: 'apprentice' });
    app.appendChild(svg('circle', { cx: g.cx, cy: g.cy, r: 24, fill: 'rgba(232,181,75,0.16)', stroke: '#e8b54b', 'stroke-width': 2 }));
    var broom = svg('text', { x: g.cx, y: g.cy + 7, 'text-anchor': 'middle', 'font-size': 22 });
    broom.textContent = '🧹'; app.appendChild(broom);
    var cap = svg('text', { x: g.cx, y: g.cy + 44, 'text-anchor': 'middle', 'font-size': 12, fill: '#f0cd84' });
    cap.textContent = 'Claude'; app.appendChild(cap);
    // Empty state: nothing sensitive is in reach — say so plainly, warmly.
    if (!(DATA.exposureFiles || []).length) {
      var clear = svg('text', { x: g.cx, y: g.cy + 92, 'text-anchor': 'middle', 'font-size': 15, fill: '#6fae8f' });
      clear.textContent = 'Nothing sensitive is in reach.'; app.appendChild(clear);
    }
    s.appendChild(app);

    var legend = el('div', { class: 'legend' }, [
      el('span', { html: '<i class="ap"></i>What Claude can reach' }),
      el('span', { html: '<i class="dz"></i>Sensitive &amp; reachable' }),
      el('span', { html: '<i class="sf"></i>Everything else (safe)' }),
    ]);
    return el('div', { class: 'map-col' }, [el('div', { class: 'map-box' }, [s]), legend]);
  }

  function settleMap() {
    document.getElementById('reachGlow-c').setAttribute('opacity', '1');
    each('#safeDots circle', function (d) { d.setAttribute('opacity', '0.5'); });
    each('#reachLines line', function (l) { l.setAttribute('opacity', '0.9'); });
    each('#fileNodes .fnode', function (g) { g.setAttribute('opacity', '1'); });
  }

  function animateMap() {
    fade('#reachGlow-c', 1, 300);
    each('#fileNodes .fnode', function (g, i) { setTimeout(function () { fadeEl(g, 1, 260); }, 250 + i * 90); });
    each('#safeDots circle', function (d, i) { setTimeout(function () { fadeEl(d, 0.5, 400); }, 400 + i * 14); });
    // the one meaningful motion: the reach reaches out and lands on each red file
    var lines = document.querySelectorAll('#reachLines line');
    Array.prototype.forEach.call(lines, function (ln, i) {
      var len = lineLen(ln);
      ln.style.strokeDasharray = len; ln.style.strokeDashoffset = len; ln.setAttribute('opacity', '0.9');
      setTimeout(function () {
        ln.style.transition = 'stroke-dashoffset .5s ease-out';
        ln.style.strokeDashoffset = '0';
        var i2 = ln.getAttribute('data-i');
        setTimeout(function () { pulse(document.querySelector('#fileNodes .fnode[data-i="' + i2 + '"] circle')); }, 480);
      }, 700 + i * 320);
    });
  }

  function pulse(circle) {
    if (!circle) return;
    var r0 = +circle.getAttribute('r'), t0 = null;
    function step(t) { if (t0 === null) t0 = t; var p = Math.min((t - t0) / 520, 1);
      circle.setAttribute('r', String(r0 + Math.sin(p * Math.PI) * 6)); if (p < 1) requestAnimationFrame(step); else circle.setAttribute('r', String(r0)); }
    requestAnimationFrame(step);
  }

  function buildFindings() {
    var col = el('div', { class: 'find-col' });
    var files = DATA.exposureFiles || [];
    var reach = files.filter(function (f) { return f.reachable; });
    var other = files.filter(function (f) { return !f.reachable; });
    // Only files Claude can actually reach go under the reach heading; sensitive
    // files it cannot reach (e.g. protected by a deny rule) are shown separately.
    if (reach.length) col.appendChild(fileSection('Files Claude can reach', reach, true));
    if (other.length) col.appendChild(fileSection('Other sensitive files (not reachable)', other, false));
    var sf = DATA.settingsFindings || [];
    if (sf.length) {
      var items = sf.map(function (f) {
        return el('div', { class: 'srow', html:
          '<span class="sev s-' + escJs(f.severity) + '">' + escJs(f.severity) + '</span> ' + escJs(f.title) +
          (f.file ? ' <span class="file">' + escJs(f.file) + '</span>' : '') });
      });
      col.appendChild(el('div', { class: 'section settingsec' }, [
        el('h2', { html: 'Your settings <small>' + sf.length + '</small>' }),
        el('div', { class: 'flist' }, items),
      ]));
    }
    return col;
  }

  function fileSection(title, list, reachable) {
    var rows = list.map(function (f) {
      var sample = (f.marks.filter(function (m) { return m.redactedMatch; })[0] || {}).redactedMatch;
      var bits = [
        el('span', { class: 'dot' }),
        el('span', { class: 'fn' }, [baseName(f.file)]),
        el('span', { class: 'meta' }, [' · ' + f.count + (f.count === 1 ? ' item' : ' items') + ' · ' + (f.severity || 'info')]),
      ];
      if (DATA.baselineActive && f.isNew) bits.push(el('span', { class: 'newt' }, ['new']));
      if (reachable) bits.push(el('span', { class: 'reach' }, ['reachable']));
      if (sample) bits.push(el('code', {}, [sample]));
      return el('div', { class: 'frow' + (reachable ? '' : ' safe'), title: f.file }, bits);
    });
    return el('div', { class: 'section reachsec' }, [
      el('h2', { html: escJs(title) + ' <small>' + list.length + '</small>' }),
      el('div', {}, rows),
    ]);
  }

  // helpers
  function baseName(p) { var s = String(p).split(/[\\\/]/); return s[s.length - 1]; }
  function each(sel, fn) { Array.prototype.forEach.call(document.querySelectorAll(sel), fn); }
  function fade(sel, to, ms) { var n = document.querySelector(sel); if (n) fadeEl(n, to, ms); }
  function fadeEl(n, to, ms) { n.style.transition = 'opacity ' + ms + 'ms ease'; n.setAttribute('opacity', String(to)); }
  function lineLen(ln) { var dx = ln.x2.baseVal.value - ln.x1.baseVal.value, dy = ln.y2.baseVal.value - ln.y1.baseVal.value; return Math.sqrt(dx*dx+dy*dy); }
  function escJs(s) { return String(s == null ? '' : s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
})();
`;

// ---------------------------------------------------------------------------
// MAIN
// ---------------------------------------------------------------------------

function main() {
  const args = parseArgs(process.argv.slice(2));
  let raw;
  try {
    raw = readInput(args.input);
  } catch (e) {
    process.stderr.write(`fantasia-visual: could not read input (${e && e.message ? e.message : e}). Pipe \`fantasia-scan --json\` in, or pass a JSON file path.\n`);
    process.exit(1);
    return;
  }

  let scan;
  try {
    scan = JSON.parse(raw);
  } catch (e) {
    process.stderr.write(`fantasia-visual: input was not valid JSON. Expected the output of \`fantasia-scan --json\`.\n`);
    process.exit(1);
    return;
  }

  const model = buildModel(scan, args.title);
  const html = renderHtml(model);

  if (args.out) {
    fs.writeFileSync(args.out, html, 'utf8');
    process.stderr.write(`fantasia-visual: wrote ${args.out}\n`);
  } else {
    process.stdout.write(html);
  }
  process.exit(0);
}

main();
