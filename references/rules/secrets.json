{
  "$schema": "fantasia/secrets-rulepack-v1",
  "description": "gitleaks-style secret detection rules. Each rule: { id, description, regex (JavaScript RegExp source, NOT Go syntax), secretGroup (capture group index holding the raw secret, default 0), entropy (min Shannon entropy of secretGroup to keep), keywords (lowercase prefilter — at least one must appear in the line/region for the rule to even run), path (JS regex on POSIX relative path), tags }.",
  "rules": [
    {
      "id": "aws-access-key-id",
      "description": "AWS Access Key ID",
      "regex": "\\b((?:AKIA|ABIA|ACCA|ASIA)[0-9A-Z]{16})\\b",
      "secretGroup": 1,
      "keywords": ["akia", "abia", "acca", "asia", "aws"],
      "tags": ["aws", "credentials"]
    },
    {
      "id": "aws-secret-access-key",
      "description": "AWS Secret Access Key (assignment with high entropy)",
      "regex": "(?i)aws[_.-]?(?:secret|sec)[_.-]?(?:access)?[_.-]?key[_.-]?(?:id)?[\"'\\s]*[:=]+[\"'\\s]*([A-Za-z0-9/+=]{40})",
      "secretGroup": 1,
      "entropy": 3.8,
      "keywords": ["aws", "secret"],
      "tags": ["aws", "credentials"]
    },
    {
      "id": "github-pat",
      "description": "GitHub Personal Access Token (classic / fine-grained)",
      "regex": "\\b((?:ghp|gho|ghu|ghs|ghr)_[0-9A-Za-z]{36}|github_pat_[0-9A-Za-z]{22}_[0-9A-Za-z]{59})\\b",
      "secretGroup": 1,
      "keywords": ["ghp_", "gho_", "ghu_", "ghs_", "ghr_", "github_pat_"],
      "tags": ["github", "credentials"]
    },
    {
      "id": "gitlab-pat",
      "description": "GitLab Personal Access Token",
      "regex": "\\b(glpat-[0-9A-Za-z_-]{20})\\b",
      "secretGroup": 1,
      "keywords": ["glpat-"],
      "tags": ["gitlab", "credentials"]
    },
    {
      "id": "slack-token",
      "description": "Slack token (bot/user/app/refresh/legacy)",
      "regex": "\\b(xox[baprs]-[0-9A-Za-z-]{10,})\\b",
      "secretGroup": 1,
      "keywords": ["xoxb-", "xoxa-", "xoxp-", "xoxr-", "xoxs-"],
      "tags": ["slack", "credentials"]
    },
    {
      "id": "slack-webhook",
      "description": "Slack incoming webhook URL",
      "regex": "(https://hooks\\.slack\\.com/services/T[0-9A-Za-z_-]+/B[0-9A-Za-z_-]+/[0-9A-Za-z_-]+)",
      "secretGroup": 1,
      "keywords": ["hooks.slack.com"],
      "tags": ["slack", "webhook"]
    },
    {
      "id": "google-api-key",
      "description": "Google API key",
      "regex": "\\b(AIza[0-9A-Za-z_-]{35})\\b",
      "secretGroup": 1,
      "keywords": ["aiza"],
      "tags": ["google", "credentials"]
    },
    {
      "id": "google-oauth-client-secret",
      "description": "Google OAuth client secret",
      "regex": "\\b(GOCSPX-[0-9A-Za-z_-]{28})\\b",
      "secretGroup": 1,
      "keywords": ["gocspx-"],
      "tags": ["google", "oauth"]
    },
    {
      "id": "stripe-secret-key",
      "description": "Stripe live secret/restricted key",
      "regex": "\\b((?:sk|rk)_live_[0-9A-Za-z]{24,99})\\b",
      "secretGroup": 1,
      "keywords": ["sk_live_", "rk_live_"],
      "tags": ["stripe", "credentials"]
    },
    {
      "id": "openai-api-key",
      "description": "OpenAI API key",
      "regex": "\\b(sk-(?:proj-)?[0-9A-Za-z_-]{20,})\\b",
      "secretGroup": 1,
      "entropy": 3.5,
      "keywords": ["sk-"],
      "tags": ["openai", "credentials"]
    },
    {
      "id": "anthropic-api-key",
      "description": "Anthropic API key",
      "regex": "\\b(sk-ant-(?:api03-)?[0-9A-Za-z_-]{20,})\\b",
      "secretGroup": 1,
      "keywords": ["sk-ant-"],
      "tags": ["anthropic", "credentials"]
    },
    {
      "id": "private-key-block",
      "description": "PEM private key block (RSA/EC/OpenSSH/PGP/DSA/generic)",
      "regex": "-----BEGIN (?:RSA |EC |OPENSSH |PGP |DSA |ENCRYPTED )?PRIVATE KEY(?: BLOCK)?-----",
      "secretGroup": 0,
      "keywords": ["-----begin", "private key"],
      "tags": ["key", "credentials", "private-key"]
    },
    {
      "id": "jwt",
      "description": "JSON Web Token",
      "regex": "\\b(eyJ[A-Za-z0-9_-]{10,}\\.eyJ[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,})\\b",
      "secretGroup": 1,
      "keywords": ["eyj"],
      "tags": ["jwt", "token"]
    },
    {
      "id": "npm-access-token",
      "description": "npm access token",
      "regex": "\\b(npm_[0-9A-Za-z]{36})\\b",
      "secretGroup": 1,
      "keywords": ["npm_"],
      "tags": ["npm", "credentials"]
    },
    {
      "id": "sendgrid-api-key",
      "description": "SendGrid API key",
      "regex": "\\b(SG\\.[0-9A-Za-z_-]{22}\\.[0-9A-Za-z_-]{43})\\b",
      "secretGroup": 1,
      "keywords": ["sg."],
      "tags": ["sendgrid", "credentials"]
    },
    {
      "id": "twilio-api-key",
      "description": "Twilio API key / Account SID",
      "regex": "\\b((?:SK|AC)[0-9a-fA-F]{32})\\b",
      "secretGroup": 1,
      "keywords": ["twilio", "sk", "ac"],
      "tags": ["twilio", "credentials"]
    },
    {
      "id": "generic-secret-assignment",
      "description": "Generic password/secret/token/apikey assignment with high-entropy value",
      "regex": "(?i)\\b(?:password|passwd|pwd|secret|api[_.-]?key|apikey|access[_.-]?token|auth[_.-]?token|client[_.-]?secret|private[_.-]?key|token)\\b[\"'\\s]*[:=]+[\"'\\s]*[\"']?([0-9A-Za-z!@#$%^&*()._/+=-]{12,80})[\"']?",
      "secretGroup": 1,
      "entropy": 3.5,
      "keywords": ["password", "passwd", "pwd", "secret", "apikey", "api_key", "api-key", "token", "client_secret", "private_key"],
      "tags": ["generic", "credentials"]
    }
  ]
}
